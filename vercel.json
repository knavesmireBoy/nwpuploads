{
    "functions": {
      "api/*.php": {
        "runtime": "vercel-php@0.8.0"
      }
    },
    "rerwrites": [
      { "source": "/(css|js|images|fonts|favicon)/(.*)", "destination": "/public/$1/$2" },
      { "source": "/(.*)\\.(.+)$", "destination": "/public/$1.$2" },
      { "source": "/(.*)", "destination": "/api/index.php" },
      { "source": "/", "destination": "/https://www.bbc.co.uk/programmes/m0001gn7" }
    ]
  }
  