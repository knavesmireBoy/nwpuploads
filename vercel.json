{
    "functions": {
      "api/*.php": {
        "runtime": "vercel-php@0.8.0"
      }
    },
    "rerwrites": [
      { "source": "/(css|js|images|fonts|favicon)/(.*)", "destination": "/public/$1/$2" },
      { "source": "/(.*)\\.(.+)$", "destination": "/public/$1.$2" },
      { "source": "/:path*", "destination": "/:path*" }
    ]
  }
  