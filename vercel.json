{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "rerwrites": [
    {
      "source": "/(css|js|images|assets|fonts|favicon)/(.*)",
      "destination": "/public/$1/$2"
    },
    { "src": "/(.*)\\.(.+)$", "dest": "/public/$1.$2" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
